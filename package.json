{
  "name": "fat-will-game",
  "private": true,
  "version": "0.0.0",
  "main": "electron.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build-electron": "npm run build && electron-builder"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "vite": "^5.2.0",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3"
  },
  "build": {
    "appId": "com.fatwill.game",
    "productName": "Fat Will Game",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron.cjs"
    ],
    "win": {
      "target": "portable"
    }
  }
}
